{
  "name": "jest-styled-components",
  "version": "7.2.0",
  "description": "Jest utilities for Styled Components",
  "type": "commonjs",
  "main": "./src/index.js",
  "types": "./typings/index.d.ts",
  "files": [
    "native",
    "serializer",
    "src",
    "typings",
    "vitest"
  ],
  "repository": "github:styled-components/jest-styled-components",
  "bugs": {
    "url": "https://github.com/styled-components/jest-styled-components/issues"
  },
  "author": "Michele Bertoli",
  "license": "MIT",
  "scripts": {
    "test": "yarn test:web && yarn test:native && yarn test:preact && yarn lint:pkg",
    "test:web": "jest --color",
    "test:web:watch": "jest --watch",
    "test:native": "jest --color --config .jest.native.json",
    "test:preact": "jest --color --config .jest.preact.json",
    "lint:pkg": "publint --pack npm && attw --pack ."
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@babel/core": "^7.0.0",
    "@babel/preset-env": "^7.16.4",
    "@babel/preset-react": "^7.0.0",
    "@biomejs/biome": "^2.4.8",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@testing-library/react": "^12.1.2",
    "@types/styled-components": "^5.1.15",
    "@wojtekmaj/enzyme-adapter-react-17": "^0.6.5",
    "babel-jest": "^27.3.1",
    "babel-plugin-styled-components": "^2.0.1",
    "enzyme": "^3.6.0",
    "enzyme-adapter-preact-pure": "^3.3.0",
    "enzyme-to-json": "^3.3.1",
    "husky-v4": "^4.3.8",
    "jest": "^27.3.1",
    "lint-staged": "^12.1.1",
    "preact": "^10.0.0-beta.2",
    "preact-render-to-json": "^3.6.6",
    "pretty-format": "^27.5.1",
    "publint": "^0.3.18",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-is": "^17.0.2",
    "react-native": "^0.66.3",
    "react-test-renderer": "^17.0.2",
    "styled-components": "^6.0.9"
  },
  "dependencies": {
    "@adobe/css-tools": "^4.4.0"
  },
  "peerDependencies": {
    "styled-components": ">= 5"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.js": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "jest": {
    "setupFiles": [
      "<rootDir>/test/__mocks__/requestAnimationFrame.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/test/setup.js"
    ],
    "snapshotSerializers": [
      "enzyme-to-json/serializer"
    ],
    "testEnvironment": "jsdom",
    "testPathIgnorePatterns": [
      "<rootDir>/test/native",
      "<rootDir>/test/preact"
    ]
  },
  "engines": {
    "node": ">= 12"
  }
}
